# App Configuration
APP_NAME=SpatialHub Webservice
APP_ENV=development
WEBSERVICE_APP_PORT=8082
WEBSERVICE_APP_HOST=0.0.0.0
APP_TIMEZONE=Europe/Berlin

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_DATABASE=spatialai
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DATABASE=0

# Backend Service Configuration
CALLBACK_URL=http://localhost:8000

# Dispatch/Concurrency Tuning
# Dispatch worker concurrency is derived from Webservice Management DB
# (`auto_scaling` + `max_concurrency`), with internal safety bounds.
# Retry delay (ms) when no webservice capacity is currently available.
WEBSERVICE_NO_CAPACITY_RETRY_MS=2000

# Scheduler Tuning
# Interval for heartbeat/status/concurrency reconciliation checks.
WEBSERVICE_SCHEDULER_INTERVAL_SECONDS=30
# Running-model timeout before marking as failed (minutes).
WEBSERVICE_STUCK_MODEL_TIMEOUT_MINUTES=720
KEYCLOAK_CLIENT_SECRET=m4AJ4Pj9NXzOdryBGio0x9Q7bww6whF5
