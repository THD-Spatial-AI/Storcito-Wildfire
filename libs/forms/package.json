{
  "name": "@spatialhub/forms",
  "version": "1.0.0",
  "description": "Universal form components for SpatialHub applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
