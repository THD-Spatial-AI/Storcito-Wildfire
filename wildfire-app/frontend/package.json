{
	"name": "frontend",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite --host",
		"build": "tsc -b && vite build",
		"lint": "eslint src --ext .ts,.tsx,.js,.jsx",
		"lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
		"preview": "vite preview",
		"check:unused:ts": "npx ts-prune | grep -v node_modules || true",
		"check:unused:exports": "npx ts-unused-exports tsconfig.app.json --excludePathsFromReport='src/tests'",
		"check:unused:deep": "npx knip",
		"check:deps": "npx depcheck",
		"test": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@internationalized/date": "^3.6.3",
		"@spatialhub/auth": "file:../../libs/auth",
		"@spatialhub/feedback": "file:../../../feeedback_pipeline/frontend_overlay",
		"@spatialhub/forms": "file:../../libs/forms",
		"@spatialhub/ui": "file:../../libs/ui",
		"@tabler/icons-react": "^3.35.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.11",
		"@tanstack/react-query": "^5.81.5",
		"@tanstack/react-virtual": "^3.13.21",
		"@turf/area": "^7.3.1",
		"@turf/buffer": "^7.2.0",
		"@turf/helpers": "^7.3.1",
		"@turf/length": "^7.3.1",
		"@types/node": "^24.0.8",
		"@types/ol": "^6.5.3",
		"axios": "^1.10.0",
		"clsx": "^2.1.1",
		"echarts": "^6.0.0",
		"echarts-for-react": "^3.0.6",
		"geojson": "^0.5.0",
		"i18next": "^24.2.3",
		"i18next-browser-languagedetector": "^8.2.1",
		"lucide-react": "^0.561.0",
		"maplibre-gl": "^5.18.0",
		"next-themes": "^0.4.6",
		"ol": "^10.6.1",
		"proj4": "^2.19.5",
		"react": "^19.1.0",
		"react-aria-components": "^1.11.0",
		"react-dom": "^19.1.0",
		"react-i18next": "^15.7.4",
		"react-joyride": "^2.9.3",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.6.3",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.3.1",
		"tailwindcss": "^4.1.11",
		"zustand": "^5.0.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.38.0",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@typescript-eslint/eslint-plugin": "^8.35.1",
		"@vitejs/plugin-react": "^4.6.0",
		"depcheck": "^1.4.7",
		"eslint": "^9.38.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.24",
		"eslint-plugin-sonarjs": "^3.0.5",
		"eslint-plugin-unused-imports": "^4.3.0",
		"globals": "^16.4.0",
		"knip": "^5.66.3",
		"ts-prune": "^0.10.3",
		"ts-unused-exports": "^11.0.1",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.46.2",
		"vite": "^7.2.1",
		"vitest": "^4.0.14"
	}
}
